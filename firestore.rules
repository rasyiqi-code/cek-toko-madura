rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(storeId) {
      return request.auth != null && request.auth.uid == storeId;
    }

    function isStaffOf(storeId) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.storeId == storeId;
    }

    match /stores/{storeId} {
      allow read, write: if isOwner(storeId) || isStaffOf(storeId);
    }

    // Staff Collection
    match /staff/{staffUid} {
      allow create: if request.auth != null;
      
      // Allow read if:
      // 1. User is the document owner
      // 2. User is the store owner (Admin)
      // 3. User is a staff member of the same store
      allow read: if request.auth != null && (
        request.auth.uid == staffUid || 
        resource.data.storeId == request.auth.uid ||
        (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.storeId == resource.data.storeId)
      );
      
      allow update, delete: if request.auth != null && (
        resource.data.storeId == request.auth.uid || 
        request.auth.uid == staffUid
      );
    }
  }
}
